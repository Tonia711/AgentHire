# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real credentials.

# ===== Avalanche Fuji contracts (live, deployed by Team 3) =====
NEXT_PUBLIC_MOCK_DNZD_ADDRESS=0x781A1Df150974E8dE40044F08eBdf4a0D7253D19
NEXT_PUBLIC_INVOICE_ADDRESS=0x2cB8295DF6F0B4AadD83686F316250a4f6fF156A
NEXT_PUBLIC_SCHEMA_REGISTRY_ADDRESS=0x94068b5a38685dEe492e57189C8e8dE9AB4E9653
NEXT_PUBLIC_EAS_ADDRESS=0xf65bC03e69f5C1a295f744c615Fc7Da79B6D0E8F
NEXT_PUBLIC_SCHEMA_UID=0xc50bb95df2ea22c7b91ea506a44e1744cb19be30870bbc433d57c8951ef07d96

# ===== WalletConnect / Reown (free, https://cloud.reown.com) =====
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-reown-project-id

# ===== Supabase (Team 2 supplies) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Required by frontend/app/api/* routes because backend tables use RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== OpenAI (server-side, AI chat) =====
# The chat route reads OPENAI_API_KEY first; ANTHROPIC_API_KEY is accepted as a
# fallback for legacy local setups.
OPENAI_API_KEY=your-openai-api-key
